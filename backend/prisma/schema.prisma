// TMS — Prisma schema (MySQL 8)
// Full schema per TMS Architecture v3 §4. snake_case via @map/@@map.
// Soft delete via deleted_at on major entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────
enum LanguagePref {
  en
  hi
  gu
}

enum OwnerType {
  own
  attached
  market
}

enum TripStatus {
  planned
  loading
  in_transit
  delivered
  cancelled
}

enum ExpenseType {
  fuel
  toll
  loading
  unloading
  repair
  bata
  halting
  misc
}

enum ExpenseStatus {
  pending
  approved
  rejected
  auto_approved
}

enum FastagDirection {
  entry
  exit
  single
}

enum FuelCardType {
  hpcl_fleetcard
  iocl_xtrarewards
  bpcl_smartfleet
  shell
  custom
}

enum InvoiceType {
  outward
  credit_note
  debit_note
}

enum InvoiceStatus {
  draft
  pending_approval
  approved
  sent
  paid
  cancelled
}

// ─────────────────────────────────────────────────────────────
// RBAC + org
// ─────────────────────────────────────────────────────────────
model Role {
  id          Int              @id @default(autoincrement()) @db.UnsignedInt
  name        String           @unique @db.VarChar(60)
  label       String           @db.VarChar(80)
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id       Int    @id @default(autoincrement()) @db.UnsignedInt
  roleId   Int    @map("role_id") @db.UnsignedInt
  resource String @db.VarChar(60)
  action   String @db.VarChar(20)
  scope    String @default("all") @db.VarChar(20)
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action], name: "role_resource_action")
  @@index([roleId])
  @@map("role_permissions")
}

model Branch {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  name      String    @db.VarChar(120)
  code      String    @unique @db.VarChar(20)
  city      String?   @db.VarChar(100)
  state     String?   @db.VarChar(100)
  stateCode String?   @map("state_code") @db.Char(2)
  address   String?   @db.Text
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users User[]
  trips Trip[]

  @@map("branches")
}

model User {
  id           Int          @id @default(autoincrement()) @db.UnsignedInt
  name         String       @db.VarChar(120)
  mobile       String       @unique @db.VarChar(15)
  email        String?      @db.VarChar(180)
  roleId       Int          @map("role_id") @db.UnsignedInt
  branchId     Int?         @map("branch_id") @db.UnsignedInt
  languagePref LanguagePref @default(en) @map("language_pref")
  isActive     Boolean      @default(true) @map("is_active")
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  role   Role    @relation(fields: [roleId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  // back-relations
  drivenVehicles      Vehicle[]      @relation("VehicleDriver")
  driverTrips         Trip[]         @relation("TripDriver")
  managedTrips        Trip[]         @relation("TripManager")
  expensesAsDriver    TripExpense[]  @relation("ExpenseDriver")
  expensesApproved    TripExpense[]  @relation("ExpenseApprover")
  fuelCardsAsDriver   FuelCard[]     @relation("FuelCardDriver")
  managedClients      Client[]       @relation("ClientAccountManager")
  invoicesCreated     Invoice[]      @relation("InvoiceCreator")
  invoicesApproved    Invoice[]      @relation("InvoiceApprover")
  auditLogs           AuditLog[]

  @@index([roleId])
  @@index([branchId])
  @@map("users")
}

model OtpSession {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  mobile         String    @db.VarChar(15)
  msg91RequestId String?   @map("msg91_request_id") @db.VarChar(120)
  otpCode        String?   @map("otp_code") @db.VarChar(120) // hashed/stubbed; null in prod MSG91 mode
  attempts       Int       @default(0)
  isVerified     Boolean   @default(false) @map("is_verified")
  expiresAt      DateTime  @map("expires_at")
  verifiedAt     DateTime? @map("verified_at")
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([mobile])
  @@map("otp_sessions")
}

// ─────────────────────────────────────────────────────────────
// Fleet
// ─────────────────────────────────────────────────────────────
model Vehicle {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  registrationNo  String    @unique @map("registration_no") @db.VarChar(20)
  vehicleType     String    @map("vehicle_type") @db.VarChar(60)
  capacityTons    Decimal?  @map("capacity_tons") @db.Decimal(6, 2)
  model           String?   @db.VarChar(80)
  ownerType       OwnerType @default(own) @map("owner_type")
  driverId        Int?      @map("driver_id") @db.UnsignedInt
  rcExpiry        DateTime? @map("rc_expiry") @db.Date
  insuranceExpiry DateTime? @map("insurance_expiry") @db.Date
  fitnessExpiry   DateTime? @map("fitness_expiry") @db.Date
  permitExpiry    DateTime? @map("permit_expiry") @db.Date
  fastagTagId     String?   @map("fastag_tag_id") @db.VarChar(30)
  fuelCardId      Int?      @map("fuel_card_id") @db.UnsignedInt
  isAvailable     Boolean   @default(true) @map("is_available")
  gpsDeviceId     String?   @map("gps_device_id") @db.VarChar(80)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  driver              User?               @relation("VehicleDriver", fields: [driverId], references: [id])
  trips               Trip[]
  fastagWallet        FastagWallet?
  fastagTransactions  FastagTransaction[]
  fuelTransactions    FuelTransaction[]
  fuelCards           FuelCard[]          @relation("FuelCardVehicle")

  @@index([driverId])
  @@map("vehicles")
}

// ─────────────────────────────────────────────────────────────
// Trips + expenses
// ─────────────────────────────────────────────────────────────
model Trip {
  id                  Int        @id @default(autoincrement()) @db.UnsignedInt
  lrNumber            String     @unique @map("lr_number") @db.VarChar(30)
  vehicleId           Int?       @map("vehicle_id") @db.UnsignedInt
  driverId            Int?       @map("driver_id") @db.UnsignedInt
  clientId            Int?       @map("client_id") @db.UnsignedInt
  branchId            Int?       @map("branch_id") @db.UnsignedInt
  originCity          String     @map("origin_city") @db.VarChar(100)
  originAddress       String?    @map("origin_address") @db.Text
  destinationCity     String     @map("destination_city") @db.VarChar(100)
  destinationAddress  String?    @map("destination_address") @db.Text
  cargoType           String?    @map("cargo_type") @db.VarChar(80)
  cargoWeightKg       Decimal?   @map("cargo_weight_kg") @db.Decimal(10, 2)
  cargoValue          Decimal?   @map("cargo_value") @db.Decimal(12, 2)
  plannedDeparture    DateTime?  @map("planned_departure")
  actualDeparture     DateTime?  @map("actual_departure")
  actualArrival       DateTime?  @map("actual_arrival")
  status              TripStatus @default(planned)
  tripManagerId       Int?       @map("trip_manager_id") @db.UnsignedInt
  podUrl              String?    @map("pod_url") @db.VarChar(500)
  ewayBillNo          String?    @map("eway_bill_no") @db.VarChar(20)
  ewayBillExpiry      DateTime?  @map("eway_bill_expiry")
  freightCharges      Decimal?   @map("freight_charges") @db.Decimal(12, 2)
  estimatedFastagToll Decimal?   @map("estimated_fastag_toll") @db.Decimal(10, 2)
  actualFastagToll    Decimal?   @map("actual_fastag_toll") @db.Decimal(10, 2)
  fuelConsumedLtr     Decimal?   @map("fuel_consumed_ltr") @db.Decimal(8, 2)
  notes               String?    @db.Text
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  vehicle            Vehicle?            @relation(fields: [vehicleId], references: [id])
  driver             User?               @relation("TripDriver", fields: [driverId], references: [id])
  client             Client?             @relation(fields: [clientId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  tripManager        User?               @relation("TripManager", fields: [tripManagerId], references: [id])
  expenses           TripExpense[]
  fastagTransactions FastagTransaction[]
  fuelTransactions   FuelTransaction[]
  invoices           Invoice[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([clientId])
  @@index([status])
  @@map("trips")
}

model TripExpense {
  id               Int           @id @default(autoincrement()) @db.UnsignedInt
  tripId           Int?          @map("trip_id") @db.UnsignedInt
  driverId         Int?          @map("driver_id") @db.UnsignedInt
  expenseType      ExpenseType   @map("expense_type")
  amount           Decimal       @db.Decimal(10, 2)
  receiptUrl       String?       @map("receipt_url") @db.VarChar(500)
  description      String?       @db.VarChar(200)
  expenseDate      DateTime?     @map("expense_date") @db.Date
  isFastagSynced   Boolean       @default(false) @map("is_fastag_synced")
  isFuelcardSynced Boolean       @default(false) @map("is_fuelcard_synced")
  status           ExpenseStatus @default(pending)
  approvedBy       Int?          @map("approved_by") @db.UnsignedInt
  approvedAt       DateTime?     @map("approved_at")
  rejectedReason   String?       @map("rejected_reason") @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  trip     Trip? @relation(fields: [tripId], references: [id])
  driver   User? @relation("ExpenseDriver", fields: [driverId], references: [id])
  approver User? @relation("ExpenseApprover", fields: [approvedBy], references: [id])

  @@index([tripId])
  @@index([driverId])
  @@index([status])
  @@map("trip_expenses")
}

// ─────────────────────────────────────────────────────────────
// FASTag
// ─────────────────────────────────────────────────────────────
model FastagWallet {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  vehicleId       Int       @unique @map("vehicle_id") @db.UnsignedInt
  tagId           String    @map("tag_id") @db.VarChar(30)
  tagIssuer       String?   @map("tag_issuer") @db.VarChar(40)
  linkedMobile    String?   @map("linked_mobile") @db.VarChar(15)
  balance         Decimal   @default(0) @db.Decimal(10, 2)
  balanceSyncedAt DateTime? @map("balance_synced_at")
  lowBalanceAlert Decimal   @default(200) @map("low_balance_alert") @db.Decimal(10, 2)
  isActive        Boolean   @default(true) @map("is_active")
  apiAccountId    String?   @map("api_account_id") @db.VarChar(80)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id])
  transactions FastagTransaction[]

  @@map("fastag_wallets")
}

model FastagTransaction {
  id             Int             @id @default(autoincrement()) @db.UnsignedInt
  fastagWalletId Int             @map("fastag_wallet_id") @db.UnsignedInt
  vehicleId      Int?            @map("vehicle_id") @db.UnsignedInt
  tripId         Int?            @map("trip_id") @db.UnsignedInt
  transactionId  String          @unique @map("transaction_id") @db.VarChar(80)
  plazaName      String?         @map("plaza_name") @db.VarChar(150)
  plazaCode      String?         @map("plaza_code") @db.VarChar(20)
  highway        String?         @db.VarChar(100)
  amount         Decimal         @db.Decimal(8, 2)
  balanceAfter   Decimal?        @map("balance_after") @db.Decimal(10, 2)
  transactionAt  DateTime        @map("transaction_at")
  direction      FastagDirection @default(single)
  vehicleClass   String?         @map("vehicle_class") @db.VarChar(20)
  rawResponse    Json?           @map("raw_response")
  syncedAt       DateTime        @default(now()) @map("synced_at")

  wallet  FastagWallet @relation(fields: [fastagWalletId], references: [id])
  vehicle Vehicle?     @relation(fields: [vehicleId], references: [id])
  trip    Trip?        @relation(fields: [tripId], references: [id])

  @@index([fastagWalletId])
  @@index([vehicleId])
  @@index([tripId])
  @@index([transactionAt])
  @@map("fastag_transactions")
}

// ─────────────────────────────────────────────────────────────
// Fuel cards
// ─────────────────────────────────────────────────────────────
model FuelCard {
  id              Int          @id @default(autoincrement()) @db.UnsignedInt
  cardNumber      String       @map("card_number") @db.VarChar(255) // AES-256 encrypted
  cardLast4       String?      @map("card_last4") @db.VarChar(8)
  cardType        FuelCardType @map("card_type")
  vehicleId       Int?         @map("vehicle_id") @db.UnsignedInt
  driverId        Int?         @map("driver_id") @db.UnsignedInt
  balance         Decimal      @default(0) @db.Decimal(10, 2)
  balanceSyncedAt DateTime?    @map("balance_synced_at")
  monthlyLimit    Decimal?     @map("monthly_limit") @db.Decimal(10, 2)
  perTxnLimit     Decimal?     @map("per_txn_limit") @db.Decimal(8, 2)
  allowedProducts Json?        @map("allowed_products")
  isActive        Boolean      @default(true) @map("is_active")
  isBlocked       Boolean      @default(false) @map("is_blocked")
  blockReason     String?      @map("block_reason") @db.VarChar(200)
  apiCardId       String?      @map("api_card_id") @db.VarChar(80)
  expiryDate      DateTime?    @map("expiry_date") @db.Date
  issuedAt        DateTime?    @map("issued_at") @db.Date
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  vehicle      Vehicle?          @relation("FuelCardVehicle", fields: [vehicleId], references: [id])
  driver       User?             @relation("FuelCardDriver", fields: [driverId], references: [id])
  transactions FuelTransaction[]

  @@index([vehicleId])
  @@index([driverId])
  @@map("fuel_cards")
}

model FuelTransaction {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  fuelCardId      Int       @map("fuel_card_id") @db.UnsignedInt
  vehicleId       Int?      @map("vehicle_id") @db.UnsignedInt
  tripId          Int?      @map("trip_id") @db.UnsignedInt
  transactionId   String    @unique @map("transaction_id") @db.VarChar(80)
  fuelStationName String?   @map("fuel_station_name") @db.VarChar(150)
  fuelStationCity String?   @map("fuel_station_city") @db.VarChar(80)
  productType     String?   @map("product_type") @db.VarChar(20)
  quantityLtr     Decimal?  @map("quantity_ltr") @db.Decimal(8, 3)
  ratePerLtr      Decimal?  @map("rate_per_ltr") @db.Decimal(8, 2)
  amount          Decimal   @db.Decimal(10, 2)
  odometerKm      Int?      @map("odometer_km") @db.UnsignedInt
  transactionAt   DateTime  @map("transaction_at")
  rawResponse     Json?     @map("raw_response")
  syncedAt        DateTime  @default(now()) @map("synced_at")

  fuelCard FuelCard @relation(fields: [fuelCardId], references: [id])
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id])
  trip     Trip?    @relation(fields: [tripId], references: [id])

  @@index([fuelCardId])
  @@index([vehicleId])
  @@index([tripId])
  @@index([transactionAt])
  @@map("fuel_transactions")
}

// ─────────────────────────────────────────────────────────────
// Clients + invoices
// ─────────────────────────────────────────────────────────────
model Client {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  companyName      String    @map("company_name") @db.VarChar(150)
  gstin            String?   @db.VarChar(15)
  pan              String?   @db.VarChar(10)
  stateCode        String?   @map("state_code") @db.Char(2)
  contactName      String?   @map("contact_name") @db.VarChar(80)
  contactMobile    String?   @map("contact_mobile") @db.VarChar(15)
  billingAddress   String?   @map("billing_address") @db.Text
  creditDays       Int       @default(30) @map("credit_days") @db.TinyInt
  rcmApplicable    Boolean   @default(true) @map("rcm_applicable")
  accountManagerId Int?      @map("account_manager_id") @db.UnsignedInt
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  accountManager User?     @relation("ClientAccountManager", fields: [accountManagerId], references: [id])
  trips          Trip[]
  invoices       Invoice[]

  @@index([accountManagerId])
  @@map("clients")
}

model Invoice {
  id               Int           @id @default(autoincrement()) @db.UnsignedInt
  invoiceNumber    String        @unique @map("invoice_number") @db.VarChar(30)
  invoiceType      InvoiceType   @default(outward) @map("invoice_type")
  clientId         Int           @map("client_id") @db.UnsignedInt
  tripId           Int?          @map("trip_id") @db.UnsignedInt
  billingMonth     String?       @map("billing_month") @db.Char(7)
  freightAmount    Decimal       @default(0) @map("freight_amount") @db.Decimal(12, 2)
  loadingCharges   Decimal       @default(0) @map("loading_charges") @db.Decimal(10, 2)
  unloadingCharges Decimal       @default(0) @map("unloading_charges") @db.Decimal(10, 2)
  detentionCharges Decimal       @default(0) @map("detention_charges") @db.Decimal(10, 2)
  otherCharges     Decimal       @default(0) @map("other_charges") @db.Decimal(10, 2)
  subtotal         Decimal       @default(0) @db.Decimal(12, 2)
  isRcm            Boolean       @default(false) @map("is_rcm")
  igstRate         Decimal       @default(0) @map("igst_rate") @db.Decimal(4, 2)
  cgstRate         Decimal       @default(0) @map("cgst_rate") @db.Decimal(4, 2)
  sgstRate         Decimal       @default(0) @map("sgst_rate") @db.Decimal(4, 2)
  igstAmount       Decimal       @default(0) @map("igst_amount") @db.Decimal(12, 2)
  cgstAmount       Decimal       @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount       Decimal       @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  tdsRate          Decimal       @default(0) @map("tds_rate") @db.Decimal(4, 2)
  tdsAmount        Decimal       @default(0) @map("tds_amount") @db.Decimal(12, 2)
  totalAmount      Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  status           InvoiceStatus @default(draft)
  dueDate          DateTime?     @map("due_date") @db.Date
  paidAt           DateTime?     @map("paid_at")
  paidAmount       Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentRef       String?       @map("payment_ref") @db.VarChar(80)
  createdBy        Int?          @map("created_by") @db.UnsignedInt
  approvedBy       Int?          @map("approved_by") @db.UnsignedInt
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  client   Client @relation(fields: [clientId], references: [id])
  trip     Trip?  @relation(fields: [tripId], references: [id])
  creator  User?  @relation("InvoiceCreator", fields: [createdBy], references: [id])
  approver User?  @relation("InvoiceApprover", fields: [approvedBy], references: [id])

  @@index([clientId])
  @@index([tripId])
  @@index([status])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────
// Audit (immutable)
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId        Int?     @map("user_id") @db.UnsignedInt
  userName      String?  @map("user_name") @db.VarChar(120)
  userRole      String?  @map("user_role") @db.VarChar(60)
  action        String   @db.VarChar(80)
  resourceType  String   @map("resource_type") @db.VarChar(60)
  resourceId    Int?     @map("resource_id") @db.UnsignedInt
  resourceLabel String?  @map("resource_label") @db.VarChar(100)
  beforeState   Json?    @map("before_state")
  afterState    Json?    @map("after_state")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(200)
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resourceType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Branding / Company Profile (singleton — single-company deployment, §1, §13)
// One row, id = 1. Read publicly by the website + dashboard; edited by admins.
// JSON columns never store secrets / API keys.
// ─────────────────────────────────────────────────────────────
model Branding {
  id          Int      @id @default(1) @db.UnsignedInt
  companyName String   @map("company_name") @db.VarChar(150)
  legalName   String?  @map("legal_name") @db.VarChar(180)
  tagline     String?  @db.VarChar(200)
  logoUrl     String?  @map("logo_url") @db.VarChar(500)
  logoDarkUrl String?  @map("logo_dark_url") @db.VarChar(500)
  faviconUrl  String?  @map("favicon_url") @db.VarChar(500)
  theme       Json?
  contact     Json?
  social      Json?
  content     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("branding")
}
