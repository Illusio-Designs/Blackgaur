{
  "name": "transport-management-system",
  "version": "0.0.0",
  "private": true,
  "description": "BlackBuck-style trucking super-app — monorepo root (backend + frontend + mobile + desktop)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:mobile": "npm run start --workspace apps/mobile",
    "dev:desktop": "npm run dev --workspace apps/desktop",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css,html}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
