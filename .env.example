# ───────────────────────────────────────────────────────────────
# Blackgaur TMS — Root environment template
# Copy to apps/api/.env and apps/web/.env.local and fill values.
# NEVER commit real secrets. All third-party keys are server-side only.
# ───────────────────────────────────────────────────────────────

# ── Database (MySQL 8) ──
DATABASE_URL="mysql://user:pass@localhost:3306/tms_db"

# ── JWT ──
JWT_SECRET="change-me-min-256-bit-hex"
JWT_REFRESH_SECRET="change-me-separate-256-bit-hex"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ── MSG91 OTP ──
MSG91_AUTH_KEY=""
MSG91_FLOW_ID=""
MSG91_SENDER_ID="TMSAPP"
MSG91_DLT_TE_ID=""
OTP_EXPIRY_SEC=300
OTP_MAX_ATTEMPTS=3
RESEND_COOLDOWN=60

# ── FASTag (IHMCL/NETC recommended) ──
IHMCL_CLIENT_ID=""
IHMCL_CLIENT_SECRET=""
IHMCL_BASE_URL="https://api.ihmcl.com/netc/v1"
HDFC_FASTAG_API_KEY=""
FASTAG_SYNC_CRON="*/15 * * * *"

# ── Fuel Cards ──
HPCL_FLEET_API_KEY=""
HPCL_FLEET_CLIENT_ID=""
IOCL_FLEET_API_KEY=""
BPCL_FLEET_API_KEY=""
FUEL_SYNC_CRON="*/30 * * * *"

# ── AWS S3 ──
AWS_S3_BUCKET="tms-documents-prod"
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Encryption (fuel card AES-256, 32-byte hex) ──
ENCRYPTION_KEY="change-me-64-hex-chars-32-bytes"

# ── Redis (OTP sessions, rate limit, cron lock) ──
REDIS_URL="redis://localhost:6379"

# ── Company profile (GST/invoice logic & PDF header) ──
COMPANY_NAME="Blackgaur Logistics Pvt Ltd"
COMPANY_GSTIN=""
COMPANY_STATE_CODE="24"

# ── Server ──
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ── Frontend (apps/web/.env.local) ──
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/v1"
