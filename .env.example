# Copy to .env and fill in. Never commit .env.
NODE_ENV=development

# Backend (Express)
BACKEND_PORT=4000

# MySQL 8.4 — install locally on Windows or point at a managed instance
DATABASE_URL=mysql://root:password@127.0.0.1:3306/tms_db

# Redis 7
REDIS_URL=redis://127.0.0.1:6379

# JWT secret (HS256 for now; swap to RS256 keys later for production)
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP provider (SMS/WhatsApp). 'stub' just logs OTPs to console for local dev.
OTP_PROVIDER=stub
OTP_LENGTH=6
OTP_TTL_SECONDS=300

# Frontend (Next.js) — public URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Mobile (Expo) — public URL of the backend API
EXPO_PUBLIC_API_URL=http://localhost:4000
